MONGO_URI="mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.example.mongodb.net/"
#MONGO_URI="mongodb://localhost:27017/"

FRONTEND_URL=http://localhost:4200
# Optional CSV list for CORS allowlist (scheme+host[:port], no paths)
# Example: CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ORIGINS=

# JWT — REQUIRED, app will NOT start without this
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# Stripe (use test keys — get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
